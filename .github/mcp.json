{
  "servers": {
		"microsoft/playwright-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@playwright/mcp@latest"
			],
			"x-metadata": {
				"registry": {
					"api": {
						"baseUrl": "https://api.mcp.github.com",
						"version": "v0.1"
					},
					"mcpServer": {
						"name": "microsoft/playwright-mcp",
						"version": "0.0.1-seed"
					}
				}
			}
		},
		"primeng": {
			"command": "npx",
			"args": [
				"-y",
				"@primeng/mcp"
			]
		},
		"angular-cli": {
			"command": "npx",
			"args": [
				"-y",
				"@angular/cli",
				"mcp"
			]
		},
		"context7": {
			"command": "npx",
			"args": [
				"-y",
				"@upstash/context7-mcp@latest"
			]
		},
		"pencil": {
			"command": "C:\\Program Files\\Pencil\\resources\\app.asar.unpacked\\out\\mcp-server-windows-x64.exe",
			"args": [
				"--app",
				"desktop"
			],
			"env": {}
		},
		"chrome-devtools-mcp": {
			"command": "npx",
			"args": [
				"-y",
				"chrome-devtools-mcp"
			]
		},
		"docker": {
			"command": "npx",
			"args": [
				"-y",
				"@tmhs/docker-mcp"
			]
		},
		"docker-hub": {
			"command": "npx",
			"args": [
				"-y",
				"@iflow-mcp/docker-dockerhub-mcp-server"
			]
		}
	}
}
